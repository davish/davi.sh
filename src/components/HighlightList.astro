---
import type { CollectionEntry } from "astro:content";
import Highlight from "./Highlight.astro";

export type Props = {
  highlights: CollectionEntry<"blog">[];
};

const { highlights } = Astro.props;
---

<ul>
  {highlights.map((p) => <Highlight post={p} />)}
</ul>

<style>
  ul {
    padding-top: 0;
    display: flex;
    flex-direction: column;
    list-style: none;
    width: 50%;
    @media (max-width: 684px) {
      padding-inline-start: 0;
      padding-top: 0;
      width: 100%;
      margin-block: 0;
    }
  }
</style>
