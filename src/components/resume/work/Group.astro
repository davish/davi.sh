---
import Job from "./Job.astro";
import type { CollectionEntry } from "astro:content";

export interface Props {
  title: string;
  jobs: CollectionEntry<"work">[];
}

const { title, jobs } = Astro.props;

const skills = [...new Set(jobs.flatMap(({ data: { skills } }) => skills))];

jobs.sort(
  (a, b) => new Date(b.data.start).getTime() - new Date(a.data.start).getTime()
);
---

{
  jobs[0] ? (
    <li class="group">
      <span class="info">
        <strong>{jobs[0].data.company}</strong>
        <span class="location">• {jobs[0].data.location}</span>
        <span class="spacer" />
      </span>
      <div class="skills">
        {skills.map((s) => (
          <span class="skill">{s}</span>
        ))}
      </div>

      <ul>
        {jobs.map((job) => (
          <li class="job">
            <Job job={job} />
          </li>
        ))}
      </ul>
    </li>
  ) : null
}

<style>
  li.group {
    list-style: none;
    margin-bottom: 0.5rem;
    @media print {
      margin-bottom: 0.5em;
    }
  }
  li.job {
    margin-bottom: 0.25rem;
    @media print {
      margin-bottom: 0.5em;
    }
    list-style: none;
  }
  .info {
    font-size: 1.2em;
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    width: 100%;

    .spacer {
      flex: 1;
    }
    .location {
      opacity: var(--dimmed-opacity);
    }
  }
  .skills {
    margin: 0.15rem 0;
    display: inline-block;
    span.skill {
      background-color: var(--background-color-solid);
      border-radius: 3px;
      padding: 0px 5px;
      &:not(:last-child) {
        margin-right: 0.5rem;
      }
    }
  }

  ul {
    padding-inline-start: 0;
  }
</style>
