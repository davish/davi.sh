---
import type { CollectionEntry } from "astro:content";
import { getUrlForCollectionEntry } from "src/content/config";
import Info from "./Info.astro";

type Props = CollectionEntry<"blog">;

const { data: frontmatter, slug } = Astro.props;

const url = getUrlForCollectionEntry("blog", slug);
---

<div>
  <h1><a href={url}>{frontmatter.title}</a></h1>
  <Info {...Astro.props} />
</div>

<style>
  div::after {
    border-bottom-color: var(--accent-color);
    content: "";
    display: block;
    width: 5em;
    border-bottom: 0.125em solid var(--accent-color);
    margin: 1.5rem 0;
  }

  h1 {
    font-family: var(--font-sans-serif);
    font-weight: 600;
    font-size: 2.1rem;
    margin: 0;
    margin-bottom: 0.3em;

    a {
      color: var(--text-color);
      text-decoration: none;
      &:hover {
        text-decoration: none;
      }
    }
  }
</style>
