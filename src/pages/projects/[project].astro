---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import ProjectLayout from "@layouts/Project.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects", (p) => !p.data.draft);
  return projects.map((p) => ({ params: { project: p.id }, props: p }));
}

export type Props = CollectionEntry<"projects">;
---

<ProjectLayout {...Astro.props} />
