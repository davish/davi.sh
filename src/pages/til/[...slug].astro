---
import Base from "@layouts/Base.astro";
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import Article from "src/components/Article.astro";
import PostContent from "src/components/blog/post/PostContent.astro";
import { getSnippets } from "src/content/config";
import { toMonthYear } from "src/utils";

export const getStaticPaths: GetStaticPaths = async () => {
  const snippets = await getSnippets();
  return snippets.map((snippet) => ({
    params: { slug: snippet.id },
    props: { entry: snippet },
  }));
};

export type Props = { entry: CollectionEntry<"snippets"> };

const {
  entry: {
    id,
    data: { title, description, published, modified },
  },
} = Astro.props;

const { Content } = await render(Astro.props.entry);
---

<Base
  path={"til/" + id}
  back="/til"
  title={description}
  description={`${title}: ${description}`}
  card={true}
>
  <Article>
    <section>
      <h4>TIL</h4>
      <h1>{description}</h1>
    </section>

    <PostContent>
      <Content />
    </PostContent>
    <h3 id="date">Last Updated in {toMonthYear(modified || published)}</h3>
  </Article>
</Base>

<style>
  section {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  h4 {
    font-family: var(--font-sans-serif);
    color: var(--accent-color);
    font-weight: 400;
    padding: 0;
    margin: 0;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  h1 {
    font-family: var(--font-sans-serif);
    padding: 0;
    margin: 0;
    margin-bottom: 3rem;
  }

  #date {
    font-family: var(--font-sans-serif);
    opacity: var(--dimmed-opacity);
    padding: 0;
    margin: 0;
    padding-top: 2rem;
    font-size: 0.8rem;
  }
</style>
